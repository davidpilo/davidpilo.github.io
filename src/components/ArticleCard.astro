---
interface Props {
  date: string;
  excerpt: string;
  href: string;
  title: string;
}

const { date, excerpt, href, title } = Astro.props;

const fmtDate = new Intl.DateTimeFormat('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
}).format(new Date(date));
---

<article class="article-card">
  <a class="card-title" href={href}>{title}</a>
  <p class="card-date">
    <span class="card-date-label">date:</span>
    <span class="card-date-value">{fmtDate}</span>
  </p>
  <p class="card-excerpt">{excerpt}</p>
  <a class="card-read-more" href={href}>
    <span class="card-line-num">:0</span> Read more ↗
  </a>
</article>

<style>
  .article-card {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    gap: 0.5rem;
    padding: 1rem;
  }

  .card-title {
    color: var(--card-title);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .card-title:hover {
    text-decoration: underline;
  }

  .card-date {
    display: flex;
    gap: 0.4rem;
    margin: 0;
  }

  .card-date-label {
    color: var(--card-date-label);
  }

  .card-date-value {
    color: var(--card-date-value);
  }

  .card-excerpt {
    color: var(--card-excerpt);
    line-height: 1.6;
    margin: 0;
  }

  .card-read-more {
    color: var(--card-link);
    margin-top: auto;
    text-decoration: none;
  }

  .card-read-more:hover {
    text-decoration: underline;
  }

  .card-line-num {
    color: var(--card-line-num);
  }
</style>
