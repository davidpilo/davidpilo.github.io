---
import { getCollection, render } from 'astro:content';

import ArticleLayout from '../../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    }
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body.split(/\s+/).length;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.date);

const relatedPosts = [prev, next]
  .filter(Boolean)
  .map(p => ({
    title: p.data.title,
    date: p.data.date.toISOString(),
    excerpt: `${p.body.substring(0, 120)}...`,
    href: `/blog/post/${p.slug}`,
  }));
---

<ArticleLayout title={post.data.title} relatedPosts={relatedPosts}>
  <div class="post-header">
    <h1>{post.data.title}</h1>
    <span>{formattedDate}</span>
  </div>

  <div class="prose">
    <Content />
  </div>
</ArticleLayout>

<style is:global>
  .prose h1 {
    color: var(--article-h1);
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1.5rem;
  }

  .prose h2 {
    color: var(--article-h2);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 2rem 0 1rem;
  }

  .prose p {
    color: var(--p-color);
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 1.25rem;
  }

  .prose ul,
  .prose ol {
    color: var(--p-color);
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .prose blockquote {
    background-color: var(--article-blockquote-bg);
    border-left: 0.2rem solid var(--article-blockquote-border);
    color: var(--article-blockquote-color);
    font-style: italic;
    margin: 1.5rem 0;
    padding: 0.75rem 1rem;
  }

  .prose blockquote p {
    margin: 0 !important;
  }

  .prose pre {
    font-size: 0.8rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    padding: 1rem;
  }

  .prose code:not(pre code) {
    background-color: var(--article-fm-bg);
    color: var(--article-fm-string);
    font-size: 0.82em;
    padding: 0.1rem 0.35rem;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--article-hr);
    margin: 2rem 0;
  }

  .prose a {
    color: var(--article-nav-link);
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }
</style>

<style>
  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-header h1 {
    color: var(--article-h1);
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1rem;
  }

  .post-header span {
    color: var(--article-meta-color);
    font-size: 0.85rem;
  }

  .vim-footer {
    color: var(--article-vim-footer);
    font-size: 0.78rem;
    margin-top: 2rem;
  }

  @media (max-width: 1199px) {
    .file-header {
      margin: -2rem -1rem 2rem;
    }
  }
</style>
